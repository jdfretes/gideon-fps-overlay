<Window x:Class="Gideon.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gideon"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        IsHitTestVisible="False"
        Left="-500" Top="-500">

    <TextBlock x:Name="FpsText"
               FontFamily="Consolas"
               FontSize="26"
               FontWeight="Bold"
               Foreground="#FF6DC800">
        <TextBlock.Effect>
            <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="1" />
        </TextBlock.Effect>
    </TextBlock>
</Window>
