<Window x:Class="Gideon.TrayPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="210" Height="262"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="True">

    <Window.Resources>
        <!-- Botón base oscuro con hover -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#FF374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#FF4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="#EE0D1117"
            BorderBrush="#25FFFFFF"
            BorderThickness="1"
            Padding="14,12">
        <StackPanel>

            <!-- Cabecera: icono + nombre + botón cerrar -->
            <Grid Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Fill="#6DC800"
                             VerticalAlignment="Center"
                             Margin="0,0,7,0"/>
                    <TextBlock Text="Gideon - FPS Overlay"
                               FontFamily="Consolas"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#F9FAFB"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource DarkBtn}"
                        Background="Transparent"
                        Width="22" Height="22"
                        Content="X"
                        FontSize="11"
                        Foreground="#6B7280"
                        Click="OnExit"
                        ToolTip="Salir de Gideon"/>
            </Grid>

            <!-- Botón toggle iniciar / detener -->
            <Button x:Name="ToggleBtn"
                    Style="{StaticResource DarkBtn}"
                    Background="#FF1F2937"
                    Height="34"
                    Margin="0,0,0,10"
                    Click="OnToggle"/>

            <!-- Separador -->
            <Rectangle Height="1" Fill="#18FFFFFF" Margin="0,0,0,10"/>

            <!-- Posición del overlay -->
            <TextBlock Text="POSICIÓN"
                       FontFamily="Consolas"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#6B7280"
                       Margin="0,0,0,8"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnTL" Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource DarkBtn}" Background="#FF1F2937"
                        Content="Arr. Izq." FontSize="11"
                        Tag="TopLeft" Click="OnCorner"/>
                <Button x:Name="BtnTR" Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource DarkBtn}" Background="#FF1F2937"
                        Content="Arr. Der." FontSize="11"
                        Tag="TopRight" Click="OnCorner"/>
                <Button x:Name="BtnBL" Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource DarkBtn}" Background="#FF1F2937"
                        Content="Ab. Izq." FontSize="11"
                        Tag="BottomLeft" Click="OnCorner"/>
                <Button x:Name="BtnBR" Grid.Row="2" Grid.Column="2"
                        Style="{StaticResource DarkBtn}" Background="#FF1F2937"
                        Content="Ab. Der." FontSize="11"
                        Tag="BottomRight" Click="OnCorner"/>
            </Grid>

            <!-- Separador -->
            <Rectangle Height="1" Fill="#18FFFFFF" Margin="0,10,0,10"/>

            <!-- Toggle: iniciar con Windows -->
            <CheckBox x:Name="ChkStartup" Cursor="Hand" Click="OnStartupToggle">
                <CheckBox.Template>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Iniciar con Windows"
                                       Foreground="#D1D5DB"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <!-- Track -->
                            <Border Grid.Column="1" x:Name="Track"
                                    Width="36" Height="18"
                                    CornerRadius="9"
                                    Background="#374151"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Thumb -->
                                <Ellipse x:Name="Thumb"
                                         Width="12" Height="12"
                                         Fill="#6B7280"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="3,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6DC800"/>
                                <Setter TargetName="Thumb"  Property="Fill"       Value="White"/>
                                <Setter TargetName="Thumb"  Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </CheckBox.Template>
            </CheckBox>

        </StackPanel>
    </Border>
</Window>
